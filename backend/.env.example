# Telegram
BOT_TOKEN=123456:ABCDEF...

# Public URL of THIS backend (used to register webhook with Telegram)
# e.g. https://tasksbot.fly.dev
PUBLIC_URL=https://tasksbot.fly.dev

# Public URL of the Mini App (Vercel domain) — used in /start button
WEBAPP_URL=https://tasksbot.vercel.app

# Random string used as Telegram webhook secret_token (X-Telegram-Bot-Api-Secret-Token)
# REQUIRED — app will not start without this. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=

# Random string used to authenticate POST /cron/tick (called by GitHub Actions cron)
# REQUIRED — app will not start without this. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=

# Postgres
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# CORS — comma-separated list of allowed origins (your Vercel domain)
# REQUIRED — do NOT use "*" in production
CORS_ORIGINS=https://tasksbot-five.vercel.app,http://localhost:5173

# Logging level
LOG_LEVEL=INFO
